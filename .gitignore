# ── Secrets: NEVER commit these ──────────────────────────
.env
.env.*
*.key
*.pem
*.p12
secrets.json
credentials.json
# ── Local backups / working files ────────────────────────
*.pre-taste
*.bak
*.tmp
_backups/
# ── Dev tooling / runtime ────────────────────────────────
.devloop/
node_modules/
# GitHub Actions workflow needs the 'workflow' OAuth scope to push;
# using deploy-on-command instead, so keep CI files out of the repo.
.github/
# ── OS cruft ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
